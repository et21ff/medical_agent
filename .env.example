# Core dependencies
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change
EMBED_MODEL=shibing624/text2vec-base-chinese

# LLM endpoint (generic keys; VLLM_* aliases are also supported)
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=local-medical-agent
LLM_MODEL=qwen2.5-7b-medical-sft
LLM_REQUEST_TIMEOUT=60

# API runtime
API_HOST=0.0.0.0
API_PORT=8080
API_DEBUG=false
EVIDENCE_PREVIEW_LIMIT=3
VECTOR_INDEX_PATH=/root/llm_learning/data/EXAM/exam_rag_faiss.index
VECTOR_META_PATH=/root/llm_learning/data/EXAM/exam_rag_meta.jsonl
GRAPH_TOP_K=3
TEXT_TOP_K=5
TEXT_RECALL_K=20
EVIDENCE_TOP_K=5

# Redis exact-key RAG cache (V1)
CACHE_ENABLED=true
CACHE_BACKEND=redis
REDIS_URL=redis://127.0.0.1:6379/0
RAG_CACHE_TTL_SECONDS=1800
RAG_CACHE_KEY_VERSION=v1
RAG_CORPUS_VERSION=exam_v1

# Redis short-term session memory
SESSION_ENABLED=true
SESSION_BACKEND=redis
SESSION_REDIS_URL=redis://127.0.0.1:6379/0
SESSION_TTL_SECONDS=604800
MAX_HISTORY_TURNS=6
